{
  "$schema": "https://design-tokens.org/schema.json",
  "color": {
    "foundation": {
      "bg": {
        "$value": "#050505",
        "$type": "color",
        "$description": "Primary background (Void)",
        "$extensions": {
          "oklch": "oklch(0.13 0 0)",
          "css": "--color-bg",
          "tailwind": "bg",
          "ansi": {
            "truecolor": "\u001b[48;2;5;5;5m",
            "256": "\u001b[48;5;232m",
            "16": "\u001b[40m"
          },
          "light": "#FAFAFA"
        }
      },
      "surface": {
        "$value": "#111111",
        "$type": "color",
        "$description": "Cards, panels, elevated areas",
        "$extensions": {
          "oklch": "oklch(0.18 0 0)",
          "css": "--color-surface",
          "tailwind": "surface.DEFAULT",
          "ansi": {
            "truecolor": "\u001b[48;2;17;17;17m",
            "256": "\u001b[48;5;233m",
            "16": "\u001b[40m"
          },
          "light": "#F1F1F1"
        }
      },
      "surface-elevated": {
        "$value": "#1E1E1E",
        "$type": "color",
        "$description": "Nested panels, popovers",
        "$extensions": {
          "oklch": "oklch(0.23 0 0)",
          "css": "--color-surface-elevated",
          "tailwind": "surface.elevated",
          "light": "#E8E8E8"
        }
      },
      "border": {
        "$value": "#1E1E1E",
        "$type": "color",
        "$description": "Structural lines, dividers",
        "$extensions": {
          "oklch": "oklch(0.23 0 0)",
          "css": "--color-border",
          "tailwind": "border.DEFAULT",
          "ansi": {
            "truecolor": "\u001b[38;2;30;30;30m",
            "256": "\u001b[38;5;234m",
            "16": "\u001b[90m"
          },
          "light": "#DFDFDF"
        }
      },
      "border-strong": {
        "$value": "#404040",
        "$type": "color",
        "$description": "Emphasized borders, focus rings",
        "$extensions": {
          "oklch": "oklch(0.33 0 0)",
          "css": "--color-border-strong",
          "tailwind": "border.strong",
          "light": "#A3A3A3"
        }
      }
    },
    "text": {
      "primary": {
        "$value": "#E8E8E8",
        "$type": "color",
        "$description": "Primary body text",
        "$extensions": {
          "oklch": "oklch(0.93 0 0)",
          "css": "--color-text",
          "tailwind": "text.DEFAULT",
          "ansi": {
            "truecolor": "\u001b[38;2;232;232;232m",
            "256": "\u001b[38;5;254m",
            "16": "\u001b[37m"
          },
          "contrast": { "on": "#050505", "ratio": "17.4:1", "aa": true, "aaa": true },
          "light": "#191919"
        }
      },
      "bright": {
        "$value": "#FAFAFA",
        "$type": "color",
        "$description": "Headlines, emphasis",
        "$extensions": {
          "oklch": "oklch(0.98 0 0)",
          "css": "--color-text-bright",
          "tailwind": "text.bright",
          "ansi": {
            "truecolor": "\u001b[38;2;250;250;250m",
            "256": "\u001b[38;5;255m",
            "16": "\u001b[97m"
          },
          "contrast": { "on": "#050505", "ratio": "19.1:1", "aa": true, "aaa": true },
          "light": "#050505"
        }
      },
      "muted": {
        "$value": "#6B6B6B",
        "$type": "color",
        "$description": "Secondary text, metadata",
        "$extensions": {
          "oklch": "oklch(0.50 0 0)",
          "css": "--color-text-muted",
          "tailwind": "text.muted",
          "ansi": {
            "truecolor": "\u001b[38;2;107;107;107m",
            "256": "\u001b[38;5;242m",
            "16": "\u001b[90m"
          },
          "contrast": { "on": "#050505", "ratio": "5.2:1", "aa": true, "aaa": false },
          "light": "#555555"
        }
      },
      "disabled": {
        "$value": "#404040",
        "$type": "color",
        "$description": "Disabled state text",
        "$extensions": {
          "oklch": "oklch(0.33 0 0)",
          "css": "--color-text-disabled",
          "tailwind": "text.disabled",
          "light": "#A3A3A3"
        }
      }
    },
    "accent": {
      "default": {
        "$value": "#E5A00D",
        "$type": "color",
        "$description": "Primary accent (brand amber)",
        "$extensions": {
          "oklch": "oklch(0.754 0.155 77.29)",
          "css": "--color-accent",
          "tailwind": "accent.DEFAULT",
          "ansi": {
            "truecolor": "\u001b[38;2;229;160;13m",
            "256": "\u001b[38;5;178m",
            "16": "\u001b[33m"
          },
          "contrast": { "on": "#050505", "ratio": "8.7:1", "aa": true, "aaa": true },
          "light": "#B07B0A"
        }
      },
      "hover": {
        "$value": "#F5C842",
        "$type": "color",
        "$description": "Hover and active states",
        "$extensions": {
          "oklch": "oklch(0.851 0.123 72.89)",
          "css": "--color-accent-hover",
          "tailwind": "accent.hover",
          "ansi": {
            "truecolor": "\u001b[38;2;245;200;66m",
            "256": "\u001b[38;5;220m",
            "16": "\u001b[93m"
          },
          "contrast": { "on": "#050505", "ratio": "12.4:1", "aa": true, "aaa": true },
          "light": "#E5A00D"
        }
      },
      "muted": {
        "$value": "#8B6914",
        "$type": "color",
        "$description": "Subtle accent, background tints",
        "$extensions": {
          "oklch": "oklch(0.504 0.104 77.04)",
          "css": "--color-accent-muted",
          "tailwind": "accent.muted",
          "ansi": {
            "truecolor": "\u001b[38;2;139;105;20m",
            "256": "\u001b[38;5;136m",
            "16": "\u001b[33m"
          },
          "light": "#4A3810"
        }
      },
      "dim": {
        "$value": "#4A3810",
        "$type": "color",
        "$description": "Accent borders, faint accent lines",
        "$extensions": {
          "oklch": "oklch(0.381 0.079 76.58)",
          "css": "--color-accent-dim",
          "tailwind": "accent.dim",
          "light": "#2E230A"
        }
      },
      "surface": {
        "$value": "#1E1707",
        "$type": "color",
        "$description": "Accent-tinted background",
        "$extensions": {
          "oklch": "oklch(0.199 0.042 77.95)",
          "css": "--color-accent-surface",
          "tailwind": "accent.surface",
          "light": "#FDF6E7"
        }
      },
      "on-accent": {
        "$value": "#050505",
        "$type": "color",
        "$description": "Text on accent backgrounds",
        "$extensions": {
          "css": "--color-on-accent",
          "tailwind": "on-accent"
        }
      }
    },
    "semantic": {
      "error": {
        "$value": "#E54D42",
        "$type": "color",
        "$description": "Error states, destructive actions",
        "$extensions": {
          "oklch": "oklch(0.629 0.19 27.95)",
          "css": "--color-error",
          "tailwind": "error.DEFAULT",
          "ansi": {
            "truecolor": "\u001b[38;2;229;77;66m",
            "256": "\u001b[38;5;167m",
            "16": "\u001b[31m"
          },
          "contrast": { "on": "#050505", "ratio": "5.3:1", "aa": true, "aaa": false }
        }
      },
      "error-muted": {
        "$value": "#3D1410",
        "$type": "color",
        "$description": "Error background tint",
        "$extensions": {
          "oklch": "oklch(0.24 0.073 27.67)",
          "css": "--color-error-muted",
          "tailwind": "error.muted"
        }
      },
      "success": {
        "$value": "#3FB950",
        "$type": "color",
        "$description": "Success states, completion",
        "$extensions": {
          "oklch": "oklch(0.695 0.181 145.62)",
          "css": "--color-success",
          "tailwind": "success.DEFAULT",
          "ansi": {
            "truecolor": "\u001b[38;2;63;185;80m",
            "256": "\u001b[38;5;71m",
            "16": "\u001b[32m"
          },
          "contrast": { "on": "#050505", "ratio": "7.0:1", "aa": true, "aaa": true }
        }
      },
      "success-muted": {
        "$value": "#0F3E17",
        "$type": "color",
        "$description": "Success background tint",
        "$extensions": {
          "oklch": "oklch(0.245 0.064 145.38)",
          "css": "--color-success-muted",
          "tailwind": "success.muted"
        }
      },
      "warning": {
        "$value": "#D29922",
        "$type": "color",
        "$description": "Warning states",
        "$extensions": {
          "oklch": "oklch(0.72 0.14 79.91)",
          "css": "--color-warning",
          "tailwind": "warning.DEFAULT",
          "ansi": {
            "truecolor": "\u001b[38;2;210;153;34m",
            "256": "\u001b[38;5;178m",
            "16": "\u001b[33m"
          },
          "contrast": { "on": "#050505", "ratio": "7.8:1", "aa": true, "aaa": true }
        }
      },
      "warning-muted": {
        "$value": "#372808",
        "$type": "color",
        "$description": "Warning background tint",
        "$extensions": {
          "oklch": "oklch(0.252 0.049 80.78)",
          "css": "--color-warning-muted",
          "tailwind": "warning.muted"
        }
      },
      "info": {
        "$value": "#58A6FF",
        "$type": "color",
        "$description": "Informational highlights",
        "$extensions": {
          "oklch": "oklch(0.715 0.152 253.3)",
          "css": "--color-info",
          "tailwind": "info.DEFAULT",
          "ansi": {
            "truecolor": "\u001b[38;2;88;166;255m",
            "256": "\u001b[38;5;75m",
            "16": "\u001b[34m"
          },
          "contrast": { "on": "#050505", "ratio": "6.4:1", "aa": true, "aaa": false }
        }
      },
      "info-muted": {
        "$value": "#0E2D52",
        "$type": "color",
        "$description": "Info background tint",
        "$extensions": {
          "oklch": "oklch(0.251 0.069 248.85)",
          "css": "--color-info-muted",
          "tailwind": "info.muted"
        }
      }
    },
    "expression": {
      "$description": "Web/marketing only -- never in terminal output",
      "lavender": {
        "$value": "#B8A9D4",
        "$type": "color",
        "$description": "Primary expression color",
        "$extensions": {
          "oklch": "oklch(0.74 0.07 296)",
          "css": "--color-expression-lavender",
          "tailwind": "expression.lavender",
          "contrast": { "on": "#050505", "ratio": "8.2:1", "aa": true, "aaa": true }
        }
      },
      "lilac": {
        "$value": "#D4C1E8",
        "$type": "color",
        "$description": "Lighter variant, gradients",
        "$extensions": {
          "oklch": "oklch(0.82 0.06 300)",
          "css": "--color-expression-lilac",
          "tailwind": "expression.lilac"
        }
      },
      "mauve": {
        "$value": "#9B87B8",
        "$type": "color",
        "$description": "Deeper variant, text on light surfaces",
        "$extensions": {
          "oklch": "oklch(0.63 0.08 293)",
          "css": "--color-expression-mauve",
          "tailwind": "expression.mauve"
        }
      },
      "rose": {
        "$value": "#E8B4C8",
        "$type": "color",
        "$description": "Warm pink, gradients, highlights",
        "$extensions": {
          "oklch": "oklch(0.80 0.06 350)",
          "css": "--color-expression-rose",
          "tailwind": "expression.rose",
          "contrast": { "on": "#050505", "ratio": "10.1:1", "aa": true, "aaa": true }
        }
      },
      "blush": {
        "$value": "#F2D1DE",
        "$type": "color",
        "$description": "Softest pink, washes",
        "$extensions": {
          "oklch": "oklch(0.88 0.04 355)",
          "css": "--color-expression-blush",
          "tailwind": "expression.blush"
        }
      }
    }
  },
  "typography": {
    "font-family": {
      "primary": {
        "$value": "'JetBrains Mono', 'Fira Code', 'Source Code Pro', 'Cascadia Code', ui-monospace, monospace",
        "$type": "fontFamily",
        "$description": "Primary typeface -- monospace for terminal + body text",
        "$extensions": {
          "css": "--font-primary",
          "tailwind": "fontFamily.primary",
          "google-fonts": "JetBrains+Mono:wght@400;500;700"
        }
      },
      "display": {
        "$value": "'Instrument Sans', 'Inter', system-ui, sans-serif",
        "$type": "fontFamily",
        "$description": "Display typeface -- web headlines 40px+ only",
        "$extensions": {
          "css": "--font-display",
          "tailwind": "fontFamily.display",
          "google-fonts": "Instrument+Sans:wght@600;700"
        }
      },
      "mono": {
        "$value": "'JetBrains Mono', 'Fira Code', ui-monospace, monospace",
        "$type": "fontFamily",
        "$description": "Monospace (alias for primary in code contexts)",
        "$extensions": {
          "css": "--font-mono",
          "tailwind": "fontFamily.mono"
        }
      }
    },
    "font-weight": {
      "regular": {
        "$value": 400,
        "$type": "fontWeight",
        "$extensions": { "css": "--font-weight-regular" }
      },
      "medium": {
        "$value": 500,
        "$type": "fontWeight",
        "$extensions": { "css": "--font-weight-medium" }
      },
      "semibold": {
        "$value": 600,
        "$type": "fontWeight",
        "$extensions": { "css": "--font-weight-semibold" }
      },
      "bold": {
        "$value": 700,
        "$type": "fontWeight",
        "$extensions": { "css": "--font-weight-bold" }
      }
    },
    "font-size": {
      "display-1": {
        "$value": "clamp(3.5rem, 8vw + 1rem, 10rem)",
        "$type": "dimension",
        "$description": "Hero headlines (72-160px)",
        "$extensions": { "css": "--text-display-1", "tailwind": "fontSize.display-1" }
      },
      "display-2": {
        "$value": "clamp(2.5rem, 4vw + 1rem, 4.5rem)",
        "$type": "dimension",
        "$description": "Section headers (48-72px)",
        "$extensions": { "css": "--text-display-2", "tailwind": "fontSize.display-2" }
      },
      "h1": {
        "$value": "clamp(1.75rem, 2vw + 1rem, 2.5rem)",
        "$type": "dimension",
        "$description": "Page titles (32-40px)",
        "$extensions": { "css": "--text-h1", "tailwind": "fontSize.h1" }
      },
      "h2": {
        "$value": "clamp(1.375rem, 1.5vw + 0.75rem, 1.75rem)",
        "$type": "dimension",
        "$description": "Section titles (24-28px)",
        "$extensions": { "css": "--text-h2", "tailwind": "fontSize.h2" }
      },
      "h3": {
        "$value": "clamp(1.125rem, 0.5vw + 1rem, 1.25rem)",
        "$type": "dimension",
        "$description": "Subsection titles (20px)",
        "$extensions": { "css": "--text-h3", "tailwind": "fontSize.h3" }
      },
      "body": {
        "$value": "1rem",
        "$type": "dimension",
        "$description": "Paragraph text (16px)",
        "$extensions": { "css": "--text-body", "tailwind": "fontSize.body" }
      },
      "body-sm": {
        "$value": "0.875rem",
        "$type": "dimension",
        "$description": "Secondary content (14px)",
        "$extensions": { "css": "--text-body-sm", "tailwind": "fontSize.body-sm" }
      },
      "caption": {
        "$value": "0.75rem",
        "$type": "dimension",
        "$description": "Metadata, labels (12px)",
        "$extensions": { "css": "--text-caption", "tailwind": "fontSize.caption" }
      },
      "overline": {
        "$value": "0.6875rem",
        "$type": "dimension",
        "$description": "Category labels, uppercase (11px)",
        "$extensions": { "css": "--text-overline", "tailwind": "fontSize.overline" }
      }
    },
    "line-height": {
      "none": { "$value": 1.0, "$type": "number", "$extensions": { "css": "--leading-none" } },
      "tight": { "$value": 1.1, "$type": "number", "$extensions": { "css": "--leading-tight" } },
      "snug": { "$value": 1.2, "$type": "number", "$extensions": { "css": "--leading-snug" } },
      "normal": { "$value": 1.4, "$type": "number", "$extensions": { "css": "--leading-normal" } },
      "relaxed": { "$value": 1.6, "$type": "number", "$extensions": { "css": "--leading-relaxed" } },
      "loose": { "$value": 1.7, "$type": "number", "$extensions": { "css": "--leading-loose" } }
    },
    "letter-spacing": {
      "tighter": { "$value": "-0.04em", "$type": "dimension", "$extensions": { "css": "--tracking-tighter" } },
      "tight": { "$value": "-0.03em", "$type": "dimension", "$extensions": { "css": "--tracking-tight" } },
      "snug": { "$value": "-0.02em", "$type": "dimension", "$extensions": { "css": "--tracking-snug" } },
      "normal": { "$value": "0", "$type": "dimension", "$extensions": { "css": "--tracking-normal" } },
      "wide": { "$value": "0.01em", "$type": "dimension", "$extensions": { "css": "--tracking-wide" } },
      "wider": { "$value": "0.02em", "$type": "dimension", "$extensions": { "css": "--tracking-wider" } },
      "widest": { "$value": "0.12em", "$type": "dimension", "$extensions": { "css": "--tracking-widest" } }
    }
  },
  "spacing": {
    "1": {
      "$value": "0.25rem",
      "$type": "dimension",
      "$description": "4px -- inline padding, icon gaps",
      "$extensions": { "css": "--space-1", "tailwind": "spacing.gsp-1", "px": 4 }
    },
    "2": {
      "$value": "0.5rem",
      "$type": "dimension",
      "$description": "8px -- default small gap",
      "$extensions": { "css": "--space-2", "tailwind": "spacing.gsp-2", "px": 8 }
    },
    "3": {
      "$value": "0.75rem",
      "$type": "dimension",
      "$description": "12px -- input padding, compact spacing",
      "$extensions": { "css": "--space-3", "tailwind": "spacing.gsp-3", "px": 12 }
    },
    "4": {
      "$value": "1rem",
      "$type": "dimension",
      "$description": "16px -- default component padding",
      "$extensions": { "css": "--space-4", "tailwind": "spacing.gsp-4", "px": 16 }
    },
    "6": {
      "$value": "1.5rem",
      "$type": "dimension",
      "$description": "24px -- card padding, section gap",
      "$extensions": { "css": "--space-6", "tailwind": "spacing.gsp-6", "px": 24 }
    },
    "8": {
      "$value": "2rem",
      "$type": "dimension",
      "$description": "32px -- section padding",
      "$extensions": { "css": "--space-8", "tailwind": "spacing.gsp-8", "px": 32 }
    },
    "12": {
      "$value": "3rem",
      "$type": "dimension",
      "$description": "48px -- section margins",
      "$extensions": { "css": "--space-12", "tailwind": "spacing.gsp-12", "px": 48 }
    },
    "16": {
      "$value": "4rem",
      "$type": "dimension",
      "$description": "64px -- page section spacing",
      "$extensions": { "css": "--space-16", "tailwind": "spacing.gsp-16", "px": 64 }
    },
    "24": {
      "$value": "6rem",
      "$type": "dimension",
      "$description": "96px -- hero padding, major dividers",
      "$extensions": { "css": "--space-24", "tailwind": "spacing.gsp-24", "px": 96 }
    }
  },
  "radius": {
    "none": {
      "$value": "0",
      "$type": "dimension",
      "$description": "Tables, code blocks, terminal-style elements",
      "$extensions": { "css": "--radius-none", "tailwind": "borderRadius.none" }
    },
    "sm": {
      "$value": "0.125rem",
      "$type": "dimension",
      "$description": "2px -- buttons, inputs, badges",
      "$extensions": { "css": "--radius-sm", "tailwind": "borderRadius.sm", "px": 2 }
    },
    "md": {
      "$value": "0.25rem",
      "$type": "dimension",
      "$description": "4px -- cards, panels, dialogs",
      "$extensions": { "css": "--radius-md", "tailwind": "borderRadius.md", "px": 4 }
    },
    "lg": {
      "$value": "0.5rem",
      "$type": "dimension",
      "$description": "8px -- large cards, hero containers (rare)",
      "$extensions": { "css": "--radius-lg", "tailwind": "borderRadius.lg", "px": 8 }
    },
    "full": {
      "$value": "9999px",
      "$type": "dimension",
      "$description": "Pills, avatars, status dots",
      "$extensions": { "css": "--radius-full", "tailwind": "borderRadius.full" }
    }
  },
  "breakpoint": {
    "sm": {
      "$value": "640px",
      "$type": "dimension",
      "$description": "Mobile",
      "$extensions": { "css": "--bp-sm", "tailwind": "screens.sm" }
    },
    "md": {
      "$value": "768px",
      "$type": "dimension",
      "$description": "Tablet",
      "$extensions": { "css": "--bp-md", "tailwind": "screens.md" }
    },
    "lg": {
      "$value": "1024px",
      "$type": "dimension",
      "$description": "Desktop",
      "$extensions": { "css": "--bp-lg", "tailwind": "screens.lg" }
    },
    "xl": {
      "$value": "1280px",
      "$type": "dimension",
      "$description": "Wide desktop",
      "$extensions": { "css": "--bp-xl", "tailwind": "screens.xl" }
    },
    "2xl": {
      "$value": "1536px",
      "$type": "dimension",
      "$description": "Ultrawide",
      "$extensions": { "css": "--bp-2xl", "tailwind": "screens.2xl" }
    }
  },
  "motion": {
    "duration": {
      "fast": {
        "$value": "100ms",
        "$type": "duration",
        "$description": "Micro-interactions, hover state changes",
        "$extensions": { "css": "--duration-fast" }
      },
      "normal": {
        "$value": "150ms",
        "$type": "duration",
        "$description": "Standard transitions, visibility changes",
        "$extensions": { "css": "--duration-normal" }
      }
    },
    "easing": {
      "default": {
        "$value": "linear",
        "$type": "cubicBezier",
        "$description": "GSP uses linear easing -- no flourish, immediate response",
        "$extensions": { "css": "--easing-default" }
      }
    }
  },
  "component": {
    "$description": "Component-level tokens for terminal UI elements",
    "diamond": {
      "empty": {
        "$value": "\u25C7",
        "$type": "string",
        "$description": "Empty diamond -- pending/not started"
      },
      "progress": {
        "$value": "\u25C8",
        "$type": "string",
        "$description": "Half-filled diamond -- in progress/active"
      },
      "filled": {
        "$value": "\u25C6",
        "$type": "string",
        "$description": "Filled diamond -- complete/done"
      }
    },
    "status": {
      "success": {
        "$value": "\u2713",
        "$type": "string",
        "$description": "Check mark -- success, passed, written"
      },
      "error": {
        "$value": "\u2717",
        "$type": "string",
        "$description": "Ballot X -- failed, broken, missing"
      },
      "warning": {
        "$value": "!",
        "$type": "string",
        "$description": "Exclamation -- caution, manual check"
      },
      "info": {
        "$value": "i",
        "$type": "string",
        "$description": "Info -- neutral information"
      }
    },
    "box": {
      "horizontal": { "$value": "\u2500", "$type": "string", "$description": "Box-drawing light horizontal" },
      "vertical": { "$value": "\u2502", "$type": "string", "$description": "Box-drawing light vertical" },
      "top-left": { "$value": "\u250C", "$type": "string", "$description": "Box-drawing light down and right" },
      "top-right": { "$value": "\u2510", "$type": "string", "$description": "Box-drawing light down and left" },
      "bottom-left": { "$value": "\u2514", "$type": "string", "$description": "Box-drawing light up and right" },
      "bottom-right": { "$value": "\u2518", "$type": "string", "$description": "Box-drawing light up and left" },
      "heavy-horizontal": { "$value": "\u2501", "$type": "string", "$description": "Box-drawing heavy horizontal" },
      "heavy-vertical": { "$value": "\u2503", "$type": "string", "$description": "Box-drawing heavy vertical" },
      "heavy-top-left": { "$value": "\u250F", "$type": "string", "$description": "Box-drawing heavy down and right" },
      "heavy-top-right": { "$value": "\u2513", "$type": "string", "$description": "Box-drawing heavy down and left" },
      "heavy-bottom-left": { "$value": "\u2517", "$type": "string", "$description": "Box-drawing heavy up and right" },
      "heavy-bottom-right": { "$value": "\u251B", "$type": "string", "$description": "Box-drawing heavy up and left" }
    },
    "tree": {
      "branch": { "$value": "\u251C\u2500\u2500 ", "$type": "string", "$description": "Tree branch (intermediate item)" },
      "last": { "$value": "\u2514\u2500\u2500 ", "$type": "string", "$description": "Tree last item" },
      "pipe": { "$value": "\u2502   ", "$type": "string", "$description": "Tree continuation (parent has more)" },
      "space": { "$value": "    ", "$type": "string", "$description": "Tree continuation (parent done)" }
    },
    "progress-bar": {
      "filled": { "$value": "\u2593", "$type": "string", "$description": "Dark shade block -- filled progress" },
      "empty": { "$value": "\u2591", "$type": "string", "$description": "Light shade block -- empty progress" }
    },
    "density-ramp": {
      "light": { "$value": "\u2591", "$type": "string", "$description": "Light shade" },
      "medium": { "$value": "\u2592", "$type": "string", "$description": "Medium shade" },
      "dark": { "$value": "\u2593", "$type": "string", "$description": "Dark shade" },
      "full": { "$value": "\u2588", "$type": "string", "$description": "Full block" }
    },
    "spinner": {
      "brand": {
        "frames": {
          "$value": ["\u25C7", "\u25C8", "\u25C6", "\u25C8"],
          "$type": "string[]",
          "$description": "Diamond cycle: empty -> progress -> filled -> progress"
        },
        "interval": {
          "$value": 80,
          "$type": "number",
          "$description": "Milliseconds per frame"
        }
      },
      "dots": {
        "frames": {
          "$value": [".  ", ".. ", "...", ".. ", ".  ", "   "],
          "$type": "string[]",
          "$description": "Dot expansion cycle"
        },
        "interval": {
          "$value": 120,
          "$type": "number",
          "$description": "Milliseconds per frame"
        }
      },
      "fallback": {
        "frames": {
          "$value": ["-", "\\", "|", "/"],
          "$type": "string[]",
          "$description": "ASCII spinner for non-Unicode terminals"
        },
        "interval": {
          "$value": 100,
          "$type": "number",
          "$description": "Milliseconds per frame"
        }
      }
    },
    "mark": {
      "lockup": { "$value": "/gsp: \u25C7\u25C7", "$type": "string", "$description": "Full brand lockup (starting state)" },
      "wordmark": { "$value": "/gsp:", "$type": "string", "$description": "Wordmark only" },
      "symbol": { "$value": "\u25C7\u25C7", "$type": "string", "$description": "Symbol only (starting state)" },
      "states": {
        "starting": { "$value": "/gsp: \u25C7\u25C7", "$type": "string" },
        "branding-active": { "$value": "/gsp: \u25C8\u25C7", "$type": "string" },
        "branding-complete": { "$value": "/gsp: \u25C6\u25C7", "$type": "string" },
        "project-active": { "$value": "/gsp: \u25C6\u25C8", "$type": "string" },
        "shipped": { "$value": "/gsp: \u25C6\u25C6", "$type": "string" }
      }
    },
    "layout": {
      "summary-box-width": {
        "$value": 44,
        "$type": "number",
        "$description": "Default summary box total width in characters"
      },
      "summary-box-max-width": {
        "$value": 60,
        "$type": "number",
        "$description": "Maximum summary box width"
      },
      "divider-width": {
        "$value": 30,
        "$type": "number",
        "$description": "Default plain divider width in characters"
      },
      "progress-bar-width": {
        "$value": 20,
        "$type": "number",
        "$description": "Default progress bar width in characters"
      },
      "progress-bar-compact-width": {
        "$value": 10,
        "$type": "number",
        "$description": "Compact progress bar width for narrow terminals"
      },
      "indent-1": {
        "$value": 2,
        "$type": "number",
        "$description": "Primary indent level in characters"
      },
      "indent-2": {
        "$value": 4,
        "$type": "number",
        "$description": "Secondary indent level in characters"
      },
      "content-width": {
        "$value": 80,
        "$type": "number",
        "$description": "Default content width in characters"
      },
      "max-content-width": {
        "$value": 120,
        "$type": "number",
        "$description": "Maximum content width in characters"
      }
    }
  }
}
