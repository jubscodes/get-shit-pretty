    "warning": {
      "$type": "color",
      "$value": "#FBBF24",
      "$description": "Warning — caution, override needed, manual check",
      "ansi": {
        "truecolor": "\u001b[38;2;251;191;36m",
        "256": "\u001b[38;5;220m",
        "16": "\u001b[33m"
      }
    },
    "error": {
      "$type": "color",
      "$value": "#EF4444",
      "$description": "Error — failure, fatal, missing",
      "ansi": {
        "truecolor": "\u001b[38;2;239;68;68m",
        "256": "\u001b[38;5;196m",
        "16": "\u001b[31m"
      }
    },
    "info": {
      "$type": "color",
      "$value": "#60A5FA",
      "$description": "Info — neutral information, prompts",
      "ansi": {
        "truecolor": "\u001b[38;2;96;165;250m",
        "256": "\u001b[38;5;75m",
        "16": "\u001b[34m"
      }
    },
    "syntax-keyword": {
      "$type": "color",
      "$value": "#FF6B35",
      "$description": "Syntax highlighting — keywords, commands, keys"
    },
    "syntax-string": {
      "$type": "color",
      "$value": "#FBBF24",
      "$description": "Syntax highlighting — strings, values, paths"
    },
    "syntax-comment": {
      "$type": "color",
      "$value": "#666666",
      "$description": "Syntax highlighting — comments, annotations"
    },
    "syntax-function": {
      "$type": "color",
      "$value": "#E0E0E0",
      "$description": "Syntax highlighting — identifiers, function names"
    },
    "syntax-number": {
      "$type": "color",
      "$value": "#60A5FA",
      "$description": "Syntax highlighting — numbers, counts"
    }
  },

  "typography": {
    "bold": {
      "$type": "string",
      "$value": "\u001b[1m",
      "$description": "Bold — headings, emphasis, brand name, key values"
    },
    "dim": {
      "$type": "string",
      "$value": "\u001b[2m",
      "$description": "Dim — secondary info, decorative, sparkle field"
    },
    "italic": {
      "$type": "string",
      "$value": "\u001b[3m",
      "$description": "Italic — descriptions, notes, voice-mode text"
    },
    "underline": {
      "$type": "string",
      "$value": "\u001b[4m",
      "$description": "Underline — links, actionable items"
    },
    "strikethrough": {
      "$type": "string",
      "$value": "\u001b[9m",
      "$description": "Strikethrough — replaced values, migration diffs"
    },
    "inverse": {
      "$type": "string",
      "$value": "\u001b[7m",
      "$description": "Inverse — inline badges, critical highlights only"
    },
    "reset": {
      "$type": "string",
      "$value": "\u001b[0m",
      "$description": "Reset all formatting"
    }
  },

  "spacing": {
    "vertical": {
      "none": {
        "$type": "dimension",
        "$value": "0 lines",
        "$description": "No vertical space — consecutive related lines"
      },
      "sm": {
        "$type": "dimension",
        "$value": "1 line",
        "$description": "Between groups within a section"
      },
      "md": {
        "$type": "dimension",
        "$value": "2 lines",
        "$description": "Between major sections, before phase headers"
      },
      "lg": {
        "$type": "dimension",
        "$value": "3 lines",
        "$description": "Hero moments only — before/after ASCII art banners"
      }
    },
    "horizontal": {
      "indent-1": {
        "$type": "dimension",
        "$value": "2 columns",
        "$description": "Default output indentation"
      },
      "indent-2": {
        "$type": "dimension",
        "$value": "4 columns",
        "$description": "Nested content, sub-items"
      },
      "indent-3": {
        "$type": "dimension",
        "$value": "6 columns",
        "$description": "Third-level nesting"
      },
      "indent-4": {
        "$type": "dimension",
        "$value": "8 columns",
        "$description": "Maximum nesting depth"
      }
    },
    "box-padding": {
      "top": {
        "$type": "dimension",
        "$value": "1 line",
        "$description": "Blank line after top border"
      },
      "bottom": {
        "$type": "dimension",
        "$value": "1 line",
        "$description": "Blank line before bottom border"
      },
      "left": {
        "$type": "dimension",
        "$value": "2 columns",
        "$description": "Spaces after left border"
      },
      "right": {
        "$type": "dimension",
        "$value": "2 columns",
        "$description": "Spaces before right border"
      }
    }
  },

  "breakpoint": {
    "narrow": {
      "$type": "dimension",
      "$value": "40 columns",
      "$description": "Minimum viable — narrow panes, split terminals"
    },
    "compact": {
      "$type": "dimension",
      "$value": "80 columns",
      "$description": "Standard terminal width — primary design target"
    },
    "wide": {
      "$type": "dimension",
      "$value": "120 columns",
      "$description": "Widescreen — expanded tables, never stretched content"
    }
  },

  "ascii": {
    "diamond": {
      "empty": {
        "$type": "string",
        "$value": "◇",
        "$description": "U+25C7 — not started"
      },
      "progress": {
        "$type": "string",
        "$value": "◈",
        "$description": "U+25C8 — in progress"
      },
      "filled": {
        "$type": "string",
        "$value": "◆",
        "$description": "U+25C6 — complete"
      }
    },
    "sparkle": {
      "star": {
        "$type": "string",
        "$value": "✧",
        "$description": "U+2727 — brand sparkle"
      },
      "dot": {
        "$type": "string",
        "$value": ".",
        "$description": "Period — subtle sparkle dot"
      },
      "middle-dot": {
        "$type": "string",
        "$value": "·",
        "$description": "U+00B7 — medium sparkle dot"
      }
    },
    "density-ramp": {
      "light": {
        "$type": "string",
        "$value": "░",
        "$description": "U+2591 — 25% density"
      },
      "medium": {
        "$type": "string",
        "$value": "▒",
        "$description": "U+2592 — 50% density"
      },
      "dark": {
        "$type": "string",
        "$value": "▓",
        "$description": "U+2593 — 75% density"
      },
      "full": {
        "$type": "string",
        "$value": "█",
        "$description": "U+2588 — 100% density"
      }
    },
    "box": {
      "top-left": { "$type": "string", "$value": "┌" },
      "top-right": { "$type": "string", "$value": "┐" },
      "bottom-left": { "$type": "string", "$value": "└" },
      "bottom-right": { "$type": "string", "$value": "┘" },
      "horizontal": { "$type": "string", "$value": "─" },
      "vertical": { "$type": "string", "$value": "│" },
      "tee-left": { "$type": "string", "$value": "├" },
      "tee-right": { "$type": "string", "$value": "┤" },
      "tee-top": { "$type": "string", "$value": "┬" },
      "tee-bottom": { "$type": "string", "$value": "┴" },
      "cross": { "$type": "string", "$value": "┼" }
    },
    "tree": {
      "branch": {
        "$type": "string",
        "$value": "├── ",
        "$description": "Intermediate tree item"
      },
      "last": {
        "$type": "string",
        "$value": "└── ",
        "$description": "Last tree item in group"
      },
      "pipe": {
        "$type": "string",
        "$value": "│   ",
        "$description": "Continuation of parent with more children"
      },
      "space": {
        "$type": "string",
        "$value": "    ",
        "$description": "Continuation past completed parent"
      }
    }
  },

  "status": {
    "success": {
      "symbol": { "$type": "string", "$value": "✓" },
      "color": { "$type": "color", "$value": "#22C55E" },
      "$description": "Complete, passed, written"
    },
    "error": {
      "symbol": { "$type": "string", "$value": "✗" },
      "color": { "$type": "color", "$value": "#EF4444" },
      "$description": "Failed, broken, missing"
    },
    "warning": {
      "symbol": { "$type": "string", "$value": "⚠" },
      "color": { "$type": "color", "$value": "#FBBF24" },
      "$description": "Caution, manual check needed"
    },
    "info": {
      "symbol": { "$type": "string", "$value": "ℹ" },
      "color": { "$type": "color", "$value": "#60A5FA" },
      "$description": "Neutral information"
    },
    "progress": {
      "symbol": { "$type": "string", "$value": "◈" },
      "color": { "$type": "color", "$value": "#FF6B35" },
      "$description": "In-progress, active"
    },
    "complete": {
      "symbol": { "$type": "string", "$value": "◆" },
      "color": { "$type": "color", "$value": "#FF6B35" },
      "$description": "Phase complete (brand-specific)"
    },
    "pending": {
      "symbol": { "$type": "string", "$value": "◇" },
      "color": { "$type": "color", "$value": "#666666" },
      "$description": "Not started, queued"
    }
  },

  "spinner": {
    "brand": {
      "frames": { "$type": "string", "$value": ["◇", "◈", "◆", "◈"] },
      "interval": { "$type": "dimension", "$value": "80ms" },
      "$description": "Diamond cycle spinner — brand identity"
    },
    "dots": {
      "frames": { "$type": "string", "$value": [".  ", ".. ", "...", ".. ", ".  ", "   "] },
      "interval": { "$type": "dimension", "$value": "120ms" },
      "$description": "Dot spinner — minimal, sub-tasks"
    },
    "fallback": {
      "frames": { "$type": "string", "$value": ["-", "\\", "|", "/"] },
      "interval": { "$type": "dimension", "$value": "100ms" },
      "$description": "ASCII fallback spinner"
    }
  },

  "mark": {
    "lockup": { "$type": "string", "$value": "/gsp: ◇◇", "$description": "Full brand lockup — starting state" },
    "wordmark": { "$type": "string", "$value": "/gsp:", "$description": "Wordmark only — inline, prompts" },
    "symbol": { "$type": "string", "$value": "◇◇", "$description": "Symbol only — compact contexts" },
    "states": {
      "starting": { "$type": "string", "$value": "/gsp: ◇◇" },
      "branding-active": { "$type": "string", "$value": "/gsp: ◈◇" },
      "branding-complete": { "$type": "string", "$value": "/gsp: ◆◇" },
      "project-active": { "$type": "string", "$value": "/gsp: ◆◈" },
      "shipped": { "$type": "string", "$value": "/gsp: ◆◆" }
    }
  },

  "component": {
    "summary-box": {
      "width": {
        "$type": "dimension",
        "$value": "44 characters",
        "$description": "Default box width (40 inner + 4 border/padding)"
      },
      "max-width": {
        "$type": "dimension",
        "$value": "60 characters",
        "$description": "Maximum box width for long content"
      }
    },
    "progress-bar": {
      "width": {
        "$type": "dimension",
        "$value": "20 characters",
        "$description": "Standard progress bar width"
      },
      "compact-width": {
        "$type": "dimension",
        "$value": "10 characters",
        "$description": "Narrow terminal progress bar width"
      },
      "filled": {
        "$type": "string",
        "$value": "▓",
        "$description": "Filled segment character"
      },
      "empty": {
        "$type": "string",
        "$value": "░",
        "$description": "Empty segment character"
      }
    },
    "divider": {
      "width": {
        "$type": "dimension",
        "$value": "30 characters",
        "$description": "Standard divider width"
      },
      "narrow-width": {
        "$type": "dimension",
        "$value": "20 characters",
        "$description": "Narrow terminal divider width"
      },
      "character": {
        "$type": "string",
        "$value": "─",
        "$description": "Divider character"
      }
    },
    "banner": {
      "max-width": {
        "$type": "dimension",
        "$value": "50 characters",
        "$description": "Maximum banner content width"
      },
      "title": {
        "$type": "string",
        "$value": "GET SHIT PRETTY",
        "$description": "Banner title text"
      },
      "density-ramp-open": {
        "$type": "string",
        "$value": "░▒▓█",
        "$description": "Opening density ramp"
      },
      "density-ramp-close": {
        "$type": "string",
        "$value": "█▓▒░",
        "$description": "Closing density ramp"
      }
    },
    "table": {
      "column-gap": {
        "$type": "dimension",
        "$value": "2 characters",
        "$description": "Minimum space between columns"
      },
      "compact-gap": {
        "$type": "dimension",
        "$value": "1 character",
        "$description": "Column gap in narrow terminals"
      },
      "missing-value": {
        "$type": "string",
        "$value": "—",
        "$description": "Placeholder for missing data (em dash)"
      }
    },
    "key-value": {
      "gutter": {
        "$type": "dimension",
        "$value": "4 characters",
        "$description": "Space between colon and value column"
      }
    },
    "prompt": {
      "question-symbol": {
        "$type": "string",
        "$value": "?",
        "$description": "Question prompt symbol"
      },
      "input-symbol": {
        "$type": "string",
        "$value": ">",
        "$description": "Input prompt symbol"
      },
      "checkbox-empty": {
        "$type": "string",
        "$value": "[ ]",
        "$description": "Unchecked multi-select option"
      },
      "checkbox-checked": {
        "$type": "string",
        "$value": "[✓]",
        "$description": "Checked multi-select option"
      }
    },
    "error-block": {
      "fatal-prefix": {
        "$type": "string",
        "$value": "Fatal:",
        "$description": "Prefix for fatal error banner title"
      }
    },
    "statusline": {
      "separator": {
        "$type": "string",
        "$value": " | ",
        "$description": "Segment separator in statusline"
      }
    },
    "pipeline-flow": {
      "connector": {
        "$type": "string",
        "$value": " ─── ",
        "$description": "Horizontal connector between phase nodes"
      },
      "branding-phases": {
        "$type": "string",
        "$value": ["discover", "strategy", "verbal", "identity", "system"],
        "$description": "Branding pipeline phase names"
      },
      "project-phases": {
        "$type": "string",
        "$value": ["brief", "research", "design", "critique", "build", "review"],
        "$description": "Project pipeline phase names"
      }
    },
    "phase-block": {
      "completion-format": {
        "$type": "string",
        "$value": "◆ {phase} complete — {count} chunks written",
        "$description": "Phase completion message template"
      }
    },
    "spinner": {
      "skip-threshold": {
        "$type": "dimension",
        "$value": "100ms",
        "$description": "Skip spinner for operations faster than this"
      },
      "elapsed-threshold": {
        "$type": "dimension",
        "$value": "10000ms",
        "$description": "Show elapsed time after this duration"
      }
    }
  }
}
