      "$description": "Secondary text — labels, descriptions, metadata",
      "ansi": {
        "truecolor": "\u001b[38;2;160;160;160m",
        "256": "\u001b[38;5;248m",
        "16": "\u001b[37m"
      }
    },
    "text-tertiary": {
      "$type": "color",
      "$value": "#666666",
      "$description": "Tertiary text — hints, decorative, sparkle field",
